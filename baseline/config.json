{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "description": "Primary development agent with full codebase access"
    },
    "compaction": {
      "description": "Session summarizer for context continuity across compactions"
    },
    "explore": {
      "description": "Fast codebase search specialist"
    },
    "general": {
      "description": "General-purpose subagent for fast, well-defined tasks; delegates complexity quickly"
    },
    "painter": {
      "description": "Image generation and editing specialist using Gemini 3 Pro Image. Use for creating UI mockups, app icons, hero images, visual assets, and editing/redacting existing images"
    },
    "plan": {
      "description": "Primary planning agent for architecture and multi-phase execution"
    },
    "review": {
      "description": "Code review, debugging, and security audit specialist"
    },
    "scout": {
      "description": "External research specialist for library docs and patterns"
    },
    "vision": {
      "description": "Visual content specialist for multimodal analysis and UI/UX guidance"
    }
  },
  "autoupdate": false,
  "compaction": {
    "auto": false,
    "reserved": 16000
  },
  "formatter": {
    "biome": {
      "command": [
        "npx",
        "@biomejs/biome",
        "check",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".json",
        ".jsonc"
      ]
    },
    "cargo-fmt": {
      "command": [
        "cargo",
        "fmt",
        "--",
        "$FILE"
      ],
      "extensions": [
        ".rs"
      ]
    },
    "java-formatter": {
      "command": [
        "google-java-format",
        "--replace",
        "$FILE"
      ],
      "environment": {
        "JAVA_HOME": "{env:JAVA_HOME}"
      },
      "extensions": [
        ".java"
      ]
    },
    "laravel-pint": {
      "command": [
        "npx",
        "laravel-pint",
        "--preset",
        "psr12",
        "$FILE"
      ],
      "extensions": [
        ".php"
      ]
    },
    "oxfmt": {
      "command": [
        "npx",
        "oxfmt",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".json",
        ".jsonc",
        ".html",
        ".css",
        ".scss",
        ".sass",
        ".md",
        ".mdx",
        ".yaml",
        ".yml"
      ]
    }
  },
  "instructions": [
    ".opencode/memory/project/user.md",
    ".opencode/memory/project/tech-stack.md",
    ".opencode/memory/project/project.md",
    ".opencode/context/git-context.md"
  ],
  "keybinds": {
    "leader": "ctrl+x",
    "session_parent": "up"
  },
  "mcp": {
    "figma-mcp-go": {
      "command": [
        "npx",
        "-y",
        "@vkhanhqui/figma-mcp-go@latest"
      ],
      "enabled": false,
      "timeout": 120000,
      "type": "local"
    },
    "tilth": {
      "command": [
        "npx",
        "-y",
        "tilth",
        "--mcp",
        "--edit"
      ],
      "enabled": true,
      "environment": {
        "TILTH_THREADS": "8"
      },
      "timeout": 120000,
      "type": "local"
    },
    "webclaw": {
      "command": [
        "webclaw-mcp"
      ],
      "enabled": true,
      "timeout": 120000,
      "type": "local"
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "cat *": "allow",
      "git branch *": "allow",
      "git checkout *": "ask",
      "git clean *": "ask",
      "git commit *": "ask",
      "git diff *": "allow",
      "git log *": "allow",
      "git merge *": "ask",
      "git push *": "ask",
      "git rebase *": "ask",
      "git reset *": "ask",
      "git status *": "allow",
      "ls *": "allow",
      "npm *": "allow",
      "npm publish *": "ask",
      "npm run db:push*": "ask",
      "npm run db:reset*": "deny",
      "npx *": "allow",
      "rm *": "deny",
      "rm -rf *": "deny",
      "sudo *": "deny"
    },
    "doom_loop": "ask",
    "edit": "allow",
    "external_directory": "ask",
    "question": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.key": "deny",
      "*.pem": "deny",
      "*credentials*": "deny",
      "*password*": "deny",
      "*secret*": "deny",
      "*token*": "deny"
    }
  },
  "share": "manual",
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "dist/**",
      "build/**",
      "*.log",
      ".DS_Store"
    ]
  }
}
